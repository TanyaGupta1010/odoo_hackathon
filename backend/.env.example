# Neon DB Connection String (Replace username, password, host, and database name with your own project credentials from the Neon dashboard)
DATABASE_URL="postgresql://postgres:yourpassword@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

PORT=5000

# Strong random secret for signing JWTs (e.g. `openssl rand -hex 32`)
JWT_SECRET="replace-with-a-long-random-string"

# Google OAuth Web client ID (same value as the frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
